<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Apache.Arrow" Version="19.0.0" />
    <PackageReference Include="Google.Protobuf" Version="3.28.3" />
    <PackageReference Include="Grpc.Net.Client" Version="2.76.0" />
    <PackageReference Include="Grpc.Core.Api" Version="2.76.0" />
    <PackageReference Include="Grpc.Net.Common" Version="2.76.0" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.11.1" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <!-- Compile non-UnityEngine SDK source files directly -->
  <ItemGroup>
    <Compile Include="..\..\..\Runtime\Core\RerunEntityPath.cs" Link="Core\RerunEntityPath.cs" />
    <Compile Include="..\..\..\Runtime\Core\RerunTimeline.cs" Link="Core\RerunTimeline.cs" />
    <Compile Include="..\..\..\Runtime\Core\RerunTimelineEntry.cs" Link="Core\RerunTimelineEntry.cs" />
    <Compile Include="..\..\..\Runtime\Encoding\IRerunEncoder.cs" Link="Encoding\IRerunEncoder.cs" />
    <Compile Include="..\..\..\Runtime\Encoding\RerunTuidGenerator.cs" Link="Encoding\RerunTuidGenerator.cs" />
    <Compile Include="..\..\..\Runtime\Encoding\Protos\Common.cs" Link="Encoding\Common.cs" />
    <Compile Include="..\..\..\Runtime\Encoding\Protos\LogMsg.cs" Link="Encoding\LogMsg.cs" />
    <Compile Include="..\..\..\Runtime\Encoding\RerunProtobufEncoding.cs" Link="Encoding\RerunProtobufEncoding.cs" />
    <Compile Include="..\..\..\Runtime\Encoding\EncodedRerunMessage.cs" Link="Encoding\EncodedRerunMessage.cs" />
    <Compile Include="..\..\..\Runtime\Transport\Grpc\Protos\SdkComms.cs" Link="Grpc\SdkComms.cs" />
    <Compile Include="..\..\..\Runtime\Transport\Grpc\Protos\SdkCommsGrpc.cs" Link="Grpc\SdkCommsGrpc.cs" />
    <Compile Include="..\..\..\Runtime\Encoding\RerunArrowIpcEncoder.cs" Link="Encoding\RerunArrowIpcEncoder.cs" />
    <!-- RrdRerunBackend uses internal IRerunBackend; tests go through encoder directly -->
    <Compile Include="..\..\..\Runtime\Encoding\ManagedRerunEncoder.cs" Link="Encoding\ManagedRerunEncoder.cs" />
    <Compile Include="..\..\..\Runtime\IO\Rrd\RrdWriter.cs" Link="IO\RrdWriter.cs" />
    <Compile Include="..\..\..\Runtime\Util\XxHash32.cs" Link="Util\XxHash32.cs" />
  </ItemGroup>

</Project>
